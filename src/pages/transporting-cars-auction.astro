---
import Layout from '../layouts/Layout.astro';

const title = 'Auction House Collection & Transport | Moving Cars';
const description =
  'Complete guide to collecting vehicles from Australian auction houses (Grays, Pickles, Manheim, Lloyds). Requirements, documents, and transport options.';

const houses = [
  {
    name: 'Grays Online',
    logo: 'bg-orange-500', // Placeholder color
    reqs: [
      'CC Moving Cars on authority email',
      'Congratulations email',
      'Lot Number & Invoice Number',
      'Buyers Number',
      'Copy of Paid Invoice (Full)',
      'Copy of Driver’s License (Both sides)',
    ],
    link: 'https://www.grays.com/automotive-trucks-and-marine/motor-vehiclesmotor-cycles/motor-vehicles',
  },
  {
    name: 'Pickles Auction',
    logo: 'bg-green-600',
    reqs: [
      'Buyer Number',
      'Sale Number',
      'Lot Number',
      'Name of Purchaser',
      'Receipt showing paid in full',
      'Copy of purchaser’s license',
    ],
    link: 'https://www.pickles.com.au/',
  },
  {
    name: 'Manheim',
    logo: 'bg-blue-600',
    reqs: [
      'Copy of Paid Invoice',
      'CC Moving Cars on authority email',
      'Lot Number',
    ],
    link: 'https://www.manheim.com.au/',
  },
  {
    name: 'Lloyds',
    logo: 'bg-black',
    reqs: ['Copy of ID', 'Copy of Invoice', 'Letter of Authority'],
    link: 'https://www.lloydsonline.com.au/',
  },
];

const faqs = [
  {
    q: 'Can I have someone else collect the vehicle on my behalf?',
    a: 'Most auction houses allow for third-party collection (like Moving Cars), provided they have the necessary documents and Letter of Authority.',
  },
  {
    q: 'What transport options do auction houses offer?',
    a: 'Some offer local delivery, but most require you to arrange your own transport with a third-party carrier like Moving Cars.',
  },
  {
    q: 'What should I do if there are damages upon collection?',
    a: 'We inspect vehicles upon pickup. However, you should strictly inspect the auction listing photos before bidding. Auction cars are typically sold "as is".',
  },
  {
    q: 'Do I need insurance before collecting?',
    a: 'Yes. Transit Warranty covers carrier negligence, but having your own Comprehensive Insurance is highly recommended for auction purchases.',
  },
];
---

<Layout title={title} description={description}>
  {/* Hero Section */}
  <section
    class="relative bg-[var(--color-primary-900)] text-white pt-24 pb-32 overflow-hidden"
  >
    <div class="absolute inset-0 z-0 opacity-20">
      <div
        class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary-950)]/90 to-[var(--color-primary-900)]/50 z-10"
      >
      </div>
      <svg
        class="w-full h-full text-[var(--color-primary-800)]"
        fill="currentColor"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
      >
        <path d="M0 100 C 20 0 50 0 100 100 Z"></path>
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <div
        class="inline-flex items-center gap-2 bg-[var(--color-accent-500)]/10 text-[var(--color-accent-500)] px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-wider mb-8 border border-[var(--color-accent-500)]/20"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent-500)]"></span>
        Specialised Service
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-8">
        Auction Car <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-accent-400)] to-[var(--color-accent-600)]"
          >Transport</span
        >
      </h1>
      <p
        class="text-xl text-[var(--color-neutral-400)] leading-relaxed max-w-2xl mx-auto mb-10"
      >
        Won a bid? We collect from all major Australian auction houses including
        Grays, Pickles, Manheim, and Lloyds.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://ratecheck.movingcars.com.au/quote/v2"
          class="inline-block bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-400)] text-[var(--color-primary-950)] font-bold py-4 px-10 rounded-xl transition-all shadow-lg shadow-[var(--color-accent-500)]/20 transform hover:-translate-y-1"
        >
          Get Auction Quote
        </a>
      </div>
    </div>
  </section>

  <main class="bg-[var(--color-neutral-50)] py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      {/* Intro Grid */}
      <div class="grid md:grid-cols-2 gap-12 mb-20">
        <div>
          <h2 class="text-3xl font-bold text-[var(--color-primary-900)] mb-6">
            Collecting Your New Vehicle
          </h2>
          <div class="prose prose-lg text-[var(--color-neutral-600)]">
            <p>
              Buying a vehicle from an auction house can be exhilarating, but
              handling the logistics requiring careful planning.
            </p>
            <p>
              Once the gavel falls, you typically have a short timeframe
              (usually 2-3 days) to collect your vehicle before storage fees
              apply. Understanding the requirements for release is crucial.
            </p>
          </div>
        </div>
        <div
          class="bg-white p-8 rounded-2xl shadow-sm border-l-4 border-[var(--color-accent-500)]"
        >
          <h3 class="text-xl font-bold text-[var(--color-primary-900)] mb-4">
            Standard Requirements
          </h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg
                class="w-6 h-6 text-[var(--color-accent-500)] flex-shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
              >
              <span class="text-[var(--color-neutral-700)]"
                ><strong>Proof of Purchase:</strong> Receipt or invoice confirming
                your winning bid.</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-6 h-6 text-[var(--color-accent-500)] flex-shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0c0 .884.896 1.6 2 1.6s2-.716 2-1.6"
                ></path></svg
              >
              <span class="text-[var(--color-neutral-700)]"
                ><strong>Valid ID:</strong> Driver's license covering the name on
                the invoice.</span
              >
            </li>
            <li class="flex items-start gap-3">
              <svg
                class="w-6 h-6 text-[var(--color-accent-500)] flex-shrink-0"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path></svg
              >
              <span class="text-[var(--color-neutral-700)]"
                ><strong>Authority to Release:</strong> If we are collecting for you,
                you MUST email the auction house giving "Moving Cars" authority.</span
              >
            </li>
          </ul>
        </div>
      </div>

      {/* House Specific Requirements */}
      <div class="mb-20">
        <h2
          class="text-3xl font-bold text-[var(--color-primary-900)] mb-8 text-center"
        >
          Specific Auction House Rules
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          {
            houses.map((house) => (
              <div class="bg-white rounded-xl shadow-sm border border-[var(--color-neutral-200)] overflow-hidden hover:shadow-md transition-shadow">
                <div class="p-6 border-b border-[var(--color-neutral-100)] flex justify-between items-center bg-[var(--color-neutral-50)]">
                  <h3 class="font-bold text-lg text-[var(--color-primary-900)]">
                    {house.name}
                  </h3>
                  <a
                    href={house.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-[var(--color-accent-600)] hover:underline flex items-center gap-1"
                  >
                    Visit Site{' '}
                    <svg
                      class="w-3 h-3"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                </div>
                <div class="p-6">
                  <ul class="space-y-2">
                    {house.reqs.map((req) => (
                      <li class="flex items-start gap-2 text-sm text-[var(--color-neutral-600)]">
                        <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-primary-500)] flex-shrink-0" />
                        <span>{req}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      {/* Important Note: Salvage */}
      <div
        class="bg-gray-900 rounded-2xl p-8 md:p-12 text-white mb-20 relative overflow-hidden"
      >
        <div class="relative z-10 flex flex-col md:flex-row items-center gap-8">
          <div class="flex-grow">
            <h2 class="text-2xl font-bold mb-4">Did you buy a "Non-Runner"?</h2>
            <p class="text-gray-300 mb-6">
              If you purchased a salvage vehicle or one listed as
              "Non-Drivable", standard carriers cannot take it. We need to know
              this BEFORE quoting to arrange a winch or forklift service.
            </p>
            <div class="flex gap-4">
              <a
                href="/transport-non-drivable-cars/"
                class="text-white underline font-bold hover:text-[var(--color-accent-400)]"
              >
                View Salvage Transport Options &rarr;
              </a>
            </div>
          </div>
          <div
            class="hidden md:block w-32 h-32 bg-white/10 rounded-full flex items-center justify-center"
          >
            <svg
              class="w-16 h-16 text-white/50"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
              ></path></svg
            >
          </div>
        </div>
      </div>

      {/* FAQ */}
      <div class="max-w-3xl mx-auto">
        <h2
          class="text-3xl font-bold text-[var(--color-primary-900)] mb-8 text-center"
        >
          Frequently Asked Questions
        </h2>
        <div class="space-y-6">
          {
            faqs.map((faq) => (
              <div class="bg-white p-6 rounded-xl shadow-sm border border-[var(--color-neutral-200)]">
                <h4 class="font-bold text-lg text-[var(--color-primary-900)] mb-2">
                  {faq.q}
                </h4>
                <p class="text-[var(--color-neutral-600)]">{faq.a}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </main>
</Layout>
