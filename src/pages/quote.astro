---
import Layout from '../layouts/Layout.astro';

const title = 'Get an Instant Car Transport Quote | Moving Cars';
const description =
  'Get a free, no-obligation quote for interstate car transport. Compare rates from trusted carriers and book online in minutes.';

const features = [
  {
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Instant Pricing',
    desc: 'No waiting for callbacks. Enter your details and see live rates immediately.',
  },
  {
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    title: 'Trusted Carriers',
    desc: 'We only partner with vetted, professional transport companies with proven track records.',
  },
  {
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
    title: 'Secure Booking',
    desc: 'Your data is protected. Book securely online with our encrypted payment system.',
  },
];
---

<Layout title={title} description={description}>
  {/* Hero Section */}
  <section
    class="relative bg-[var(--color-primary-900)] text-white pt-24 pb-32 overflow-hidden"
  >
    <div class="absolute inset-0 z-0 opacity-20">
      <div
        class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary-950)]/90 to-[var(--color-primary-900)]/50 z-10"
      >
      </div>
      <svg
        class="w-full h-full text-[var(--color-primary-800)]"
        fill="currentColor"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
      >
        <path d="M0 100 C 20 0 50 0 100 100 Z"></path>
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mb-8">
        Get Your <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-accent-400)] to-[var(--color-accent-600)]"
          >Free Quote</span
        >
      </h1>
      <p
        class="text-xl text-[var(--color-neutral-400)] leading-relaxed max-w-2xl mx-auto mb-12"
      >
        Compare rates for interstate car transport in seconds. Whether you're
        moving a family sedan, a luxury vehicle, or a non-runner, we have a
        solution.
      </p>

      {/* Main CTA Box */}
      <div
        class="bg-white rounded-2xl p-8 shadow-2xl max-w-xl mx-auto border border-[var(--color-neutral-200)]"
      >
        <p class="text-[var(--color-primary-900)] font-bold text-lg mb-6">
          Where are you moving?
        </p>
        <a
          href="https://ratecheck.movingcars.com.au/quote/v2"
          class="block w-full bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-400)] text-[var(--color-primary-950)] font-bold text-xl py-5 px-8 rounded-xl transition-all transform hover:-translate-y-1 shadow-lg shadow-[var(--color-accent-500)]/20"
        >
          Start Your Quote &rarr;
        </a>
        <p class="text-sm text-[var(--color-neutral-500)] mt-4">
          Takes less than 30 seconds. No credit card required to view rates.
        </p>
      </div>
    </div>
  </section>

  <main class="bg-[var(--color-neutral-50)] py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      {/* Features Grid */}
      <div class="grid md:grid-cols-3 gap-8 mb-20">
        {
          features.map((feature) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-[var(--color-neutral-100)] text-center">
              <div class="w-14 h-14 bg-[var(--color-primary-50)] text-[var(--color-primary-600)] rounded-xl flex items-center justify-center mx-auto mb-6">
                <svg
                  class="w-7 h-7"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d={feature.icon}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-[var(--color-primary-900)] mb-3">
                {feature.title}
              </h3>
              <p class="text-[var(--color-neutral-600)] leading-relaxed">
                {feature.desc}
              </p>
            </div>
          ))
        }
      </div>

      {/* Trust Section */}
      <div class="text-center">
        <h2 class="text-3xl font-bold text-[var(--color-primary-900)] mb-6">
          Moving Australia Since 2008
        </h2>
        <p class="text-[var(--color-neutral-600)] max-w-2xl mx-auto mb-10">
          We have helped thousands of Australians move their vehicles safely and
          affordably. Trust the experts for your next move.
        </p>
        <div class="flex justify-center gap-6 grayscale opacity-60">
          {/* Simple Trust Badges (SVGs could go here, using text for now) */}
          <span class="font-bold text-xl text-[var(--color-neutral-400)]"
            >★ 4.9/5 Rating</span
          >
          <span class="font-bold text-xl text-[var(--color-neutral-400)]"
            >|</span
          >
          <span class="font-bold text-xl text-[var(--color-neutral-400)]"
            >Fully Insured Options</span
          >
          <span class="font-bold text-xl text-[var(--color-neutral-400)]"
            >|</span
          >
          <span class="font-bold text-xl text-[var(--color-neutral-400)]"
            >Australia Wide</span
          >
        </div>
      </div>
    </div>
  </main>
</Layout>
