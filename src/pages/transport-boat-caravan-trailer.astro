---
import Layout from '../layouts/Layout.astro';

const title = 'Boat, Caravan & Trailer Transport | Tow-Away Service';
const description =
  'Interstate transport for boats, caravans, and trailers. We offer specialized tow-away and carrier services for your recreational vehicles.';

const requirements = [
  {
    title: 'Dimensions are Critical',
    desc: 'Unlike standard cars, every boat or caravan is different. We need exact Length, Width, and Height (including A-frame and AC units) to quote accurately.',
    icon: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
  },
  {
    title: 'Roadworthy Trailer',
    desc: 'For tow-away services, your trailer must be registered, roadworthy, have working lights, and good tyres.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Empty Tanks',
    desc: 'Please ensure water and waste tanks are empty to reduce weight and prevent instability during transport.',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  },
];
---

<Layout title={title} description={description}>
  {/* Hero Section */}
  <section
    class="relative bg-[var(--color-primary-900)] text-white pt-24 pb-32 overflow-hidden"
  >
    <div class="absolute inset-0 z-0 opacity-20">
      <div
        class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary-950)]/90 to-[var(--color-primary-900)]/50 z-10"
      >
      </div>
      <svg
        class="w-full h-full text-[var(--color-primary-800)]"
        fill="currentColor"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
      >
        <path d="M0 100 C 20 0 50 0 100 100 Z"></path>
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <div
        class="inline-flex items-center gap-2 bg-[var(--color-accent-500)]/10 text-[var(--color-accent-500)] px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-wider mb-8 border border-[var(--color-accent-500)]/20"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent-500)]"></span>
        Recreational Vehicles
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-8">
        Boat, Caravan & <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-accent-400)] to-[var(--color-accent-600)]"
          >Trailer Transport</span
        >
      </h1>
      <p
        class="text-xl text-[var(--color-neutral-400)] leading-relaxed max-w-2xl mx-auto mb-10"
      >
        Moving a holiday home on wheels or a vessel requires specialized care.
        We provide professional tow-away and flatbed solutions for your oversize
        toys.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://ratecheck.movingcars.com.au/quote/v2"
          class="bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-400)] text-[var(--color-primary-950)] font-bold py-4 px-8 rounded-xl transition-all shadow-lg hover:shadow-[var(--color-accent-500)]/20 transform hover:-translate-y-1"
        >
          Get Dimensions Quote
        </a>
      </div>
    </div>
  </section>

  <main class="bg-[var(--color-neutral-50)] py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      {/* Intro */}
      <div class="prose prose-lg prose-slate mx-auto mb-20 text-center">
        <p class="text-xl leading-relaxed text-[var(--color-neutral-600)]">
          Whether you've bought a caravan interstate or are moving your boat to
          a new marina, Moving Cars has the logistics network to help. Because
          these vehicles vary wildly in size, we offer bespoke quoting based on
          your specific dimensions.
        </p>
      </div>

      {/* Features Grid */}
      <div class="grid md:grid-cols-3 gap-8 mb-24">
        {
          requirements.map((item) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-[var(--color-neutral-100)] hover:border-[var(--color-accent-200)] transition-colors">
              <div class="w-12 h-12 bg-[var(--color-primary-50)] text-[var(--color-primary-600)] rounded-xl flex items-center justify-center mb-6">
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d={item.icon}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-[var(--color-primary-900)] mb-3">
                {item.title}
              </h3>
              <p class="text-[var(--color-neutral-600)] text-sm leading-relaxed">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>

      {/* Quote Guide Block */}
      <div
        class="bg-[var(--color-primary-900)] rounded-[3rem] p-10 md:p-16 text-white relative overflow-hidden"
      >
        <div
          class="absolute top-0 left-0 w-full h-full opacity-10 bg-[radial-gradient(circle_at_top_right,_var(--color-accent-500),_transparent_70%)]"
        >
        </div>

        <div class="relative z-10 max-w-3xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-8">How to get a Quote</h2>
          <p class="text-lg text-[var(--color-neutral-300)] mb-10">
            Because boats and caravans aren't standard sizes, our online
            calculator needs specific inputs. Please have your registration
            papers handy to verify:
          </p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="bg-white/10 p-4 rounded-xl border border-white/10">
              <div
                class="text-[var(--color-accent-400)] font-bold text-2xl mb-1"
              >
                L
              </div>
              <div class="text-sm">Total Length</div>
            </div>
            <div class="bg-white/10 p-4 rounded-xl border border-white/10">
              <div
                class="text-[var(--color-accent-400)] font-bold text-2xl mb-1"
              >
                W
              </div>
              <div class="text-sm">Max Width</div>
            </div>
            <div class="bg-white/10 p-4 rounded-xl border border-white/10">
              <div
                class="text-[var(--color-accent-400)] font-bold text-2xl mb-1"
              >
                H
              </div>
              <div class="text-sm">Max Height</div>
            </div>
            <div class="bg-white/10 p-4 rounded-xl border border-white/10">
              <div
                class="text-[var(--color-accent-400)] font-bold text-2xl mb-1"
              >
                kg
              </div>
              <div class="text-sm">Empty Weight</div>
            </div>
          </div>

          <a
            href="https://ratecheck.movingcars.com.au/quote/v2"
            class="inline-block bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-400)] text-[var(--color-primary-950)] font-bold py-4 px-10 rounded-xl transition-all"
          >
            Start My Quote
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
