---
import Layout from '../../layouts/Layout.astro';

const title = 'Car Transport Guide | Advice & Resources';
const description =
  'Complete guide to interstate vehicle transport. Transit times, warranty coverage, depot locations, and expert advice for a smooth move.';

const guides = [
  {
    title: 'Expert Advice & Tips',
    desc: 'Essential "Do\'s and Don\'ts" for preparing your car. Make sure your vehicle is ready for transport.',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
    link: '/transport-guide/advice/',
    color: 'bg-amber-500',
  },
  {
    title: 'Transit Times',
    desc: 'How long does it take? Estimated duration for popular routes like Perth to Melbourne, Brisbane to Sydney.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
    link: '/transport-guide/transit-times/',
    color: 'bg-blue-500',
  },
  {
    title: 'Transit Warranty',
    desc: 'Understanding your coverage. What is protected during transit and the terms of our service warranty.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    link: '/transport-guide/transit-warranty/',
    color: 'bg-emerald-500',
  },
  {
    title: 'Depots & Call/Meet',
    desc: 'Find our depot locations and designated call-to-meet points across Australia for drop-off and collection.',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z',
    link: '/transport-guide/depots/',
    color: 'bg-indigo-500',
  },
  {
    title: 'Delays & Policy',
    desc: 'Why delays happen and how we handle them. Information on rail schedules, trucks, and unforeseen events.',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
    link: '/transport-guide/delays/',
    color: 'bg-red-500',
  },
];
---

<Layout title={title} description={description}>
  {/* Hero Section */}
  <section
    class="relative bg-[var(--color-primary-900)] text-white pt-24 pb-32 overflow-hidden"
  >
    <div class="absolute inset-0 z-0 opacity-20">
      <div
        class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary-950)]/90 to-[var(--color-primary-900)]/50 z-10"
      >
      </div>
      <svg
        class="w-full h-full text-[var(--color-primary-800)]"
        fill="currentColor"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
      >
        <path d="M0 100 C 20 0 50 0 100 100 Z"></path>
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <div
        class="inline-flex items-center gap-2 bg-[var(--color-accent-500)]/10 text-[var(--color-accent-500)] px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-wider mb-8 border border-[var(--color-accent-500)]/20"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent-500)]"></span>
        Help Centre
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-8">
        Transport Guide & <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-accent-400)] to-[var(--color-accent-600)]"
          >Resources</span
        >
      </h1>
      <p
        class="text-xl text-[var(--color-neutral-400)] leading-relaxed max-w-2xl mx-auto mb-10"
      >
        Everything you need to know about moving your car. From expert
        preparation tips to understanding warranty and transit times.
      </p>
    </div>
  </section>

  <main class="bg-[var(--color-neutral-50)] py-20">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          guides.map((guide) => (
            <a
              href={guide.link}
              class="group bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300 border border-[var(--color-neutral-100)] flex flex-col h-full transform hover:-translate-y-1"
            >
              <div
                class={`w-14 h-14 ${guide.color} bg-opacity-10 rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300`}
              >
                <svg
                  class={`w-7 h-7 ${guide.color.replace('bg-', 'text-')}`}
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d={guide.icon}
                  />
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-[var(--color-primary-900)] mb-3 group-hover:text-[var(--color-accent-500)] transition-colors">
                {guide.title}
              </h3>
              <p class="text-[var(--color-neutral-600)] leading-relaxed mb-6 flex-grow">
                {guide.desc}
              </p>
              <div class="flex items-center text-[var(--color-accent-500)] font-bold text-sm uppercase tracking-wider">
                Read Guide
                <svg
                  class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </div>
            </a>
          ))
        }
      </div>

      {/* Support CTA */}
      <div
        class="mt-20 bg-[var(--color-primary-900)] rounded-[2rem] p-12 text-center relative overflow-hidden"
      >
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-3xl font-bold text-white mb-6">
            Still have questions?
          </h2>
          <p class="text-[var(--color-neutral-400)] mb-8 text-lg">
            Our team is ready to help. If you can't find the answer in our
            guide, reach out to us directly.
          </p>
          <div class="flex justify-center gap-4">
            <a
              href="/contact/"
              class="bg-white text-[var(--color-primary-900)] hover:bg-[var(--color-neutral-100)] font-bold py-3 px-8 rounded-xl transition-colors"
            >
              Contact Support
            </a>
            <a
              href="/faq/"
              class="bg-transparent border border-white/20 text-white hover:bg-white/10 font-bold py-3 px-8 rounded-xl transition-colors"
            >
              View FAQ
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
