---
import Layout from '../layouts/Layout.astro';

const title = 'Classic & Vintage Car Transport | Moving Cars';
const description =
  'Trusted transport for classic, vintage, and veteran vehicles. We understand the care, passion, and specific handling requirements for your prized possession.';

const features = [
  {
    title: 'Low Clearance Handling',
    desc: 'Specialized ramps and hydraulic tailgates for vehicles with low ground clearance.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Soft-Tie System',
    desc: 'We use over-the-tyre strapping systems to ensure no metal parts touch your vehicle’s chassis or suspension.',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    title: 'Enclosed Options',
    desc: 'For the ultimate protection, choose our fully enclosed service to shield your classic from the elements.',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  },
];

const prepChecklist = [
  'Photograph the vehicle from all angles for your records.',
  'Check battery charge (older electrical systems can drain quickly).',
  'Ensure fluids are topped up but not overfilled (to prevent leaks).',
  'Secure any loose convertible tops or removable parts.',
  'Empty the boot of spare parts (unless securely boxed and pre-approved).',
];
---

<Layout title={title} description={description}>
  {/* Hero Section */}
  <section
    class="relative bg-[var(--color-primary-900)] text-white pt-24 pb-32 overflow-hidden"
  >
    <div class="absolute inset-0 z-0 opacity-20">
      <div
        class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary-950)]/90 to-[var(--color-primary-900)]/50 z-10"
      >
      </div>
      <svg
        class="w-full h-full text-[var(--color-primary-800)]"
        fill="currentColor"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
      >
        <path d="M0 100 C 20 0 50 0 100 100 Z"></path>
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <div
        class="inline-flex items-center gap-2 bg-[var(--color-accent-500)]/10 text-[var(--color-accent-500)] px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-wider mb-8 border border-[var(--color-accent-500)]/20"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent-500)]"></span>
        Collectors & Enthusiasts
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-8">
        Classic & Vintage <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-accent-400)] to-[var(--color-accent-600)]"
          >Car Transport</span
        >
      </h1>
      <p
        class="text-xl text-[var(--color-neutral-400)] leading-relaxed max-w-2xl mx-auto mb-10"
      >
        It’s not just a car; it’s a piece of history. We treat your vintage
        vehicle with the respect it deserves, from soft-tie lockdowns to
        white-glove delivery.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://ratecheck.movingcars.com.au/quote/v2"
          class="bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-400)] text-[var(--color-primary-950)] font-bold py-4 px-8 rounded-xl transition-all shadow-lg hover:shadow-[var(--color-accent-500)]/20 transform hover:-translate-y-1"
        >
          Quote for Classic Car
        </a>
      </div>
    </div>
  </section>

  <main class="bg-[var(--color-neutral-50)] py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      {/* Intro */}
      <div class="prose prose-lg prose-slate mx-auto mb-20 text-center">
        <p class="text-xl leading-relaxed text-[var(--color-neutral-600)]">
          Transporting a classic car requires more than just a truck. It
          requires an understanding of vintage mechanics, delicate suspensions,
          and the emotional value of the vehicle. At Moving Cars, we are car
          enthusiasts ourselves. We know that a 1960s Mustang needs different
          care than a 2024 Corolla.
        </p>
      </div>

      {/* Features Grid */}
      <div class="grid md:grid-cols-3 gap-8 mb-24">
        {
          features.map((item) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-[var(--color-neutral-100)] hover:border-[var(--color-accent-200)] transition-colors">
              <div class="w-12 h-12 bg-[var(--color-primary-50)] text-[var(--color-primary-600)] rounded-xl flex items-center justify-center mb-6">
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d={item.icon}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-[var(--color-primary-900)] mb-3">
                {item.title}
              </h3>
              <p class="text-[var(--color-neutral-600)] text-sm leading-relaxed">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>

      {/* Preparation Section */}
      <div class="grid md:grid-cols-2 gap-12 items-center mb-24">
        <div
          class="bg-white p-10 rounded-[2rem] shadow-xl border border-[var(--color-neutral-100)]"
        >
          <div class="flex items-center gap-4 mb-6">
            <div
              class="w-10 h-10 rounded-full bg-[var(--color-accent-100)] flex items-center justify-center text-[var(--color-accent-600)]"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
                ></path></svg
              >
            </div>
            <h2 class="text-2xl font-bold text-[var(--color-primary-900)]">
              Pre-Transport Checklist
            </h2>
          </div>
          <ul class="space-y-4">
            {
              prepChecklist.map((item) => (
                <li class="flex items-start gap-3 text-[var(--color-neutral-700)]">
                  <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-accent-500)] flex-shrink-0" />
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-8">
          <h2 class="text-3xl font-bold text-[var(--color-primary-900)]">
            Club Member?
          </h2>
          <p class="text-[var(--color-neutral-600)] text-lg leading-relaxed">
            We actively support Australian Car Clubs. If you are moving a
            vehicle for a club event, rally, or show, ask us about our special
            club rates and group booking discounts.
          </p>
          <div
            class="glass-panel-dark p-8 rounded-2xl relative overflow-hidden"
          >
            <div
              class="absolute top-0 right-0 w-32 h-32 bg-[var(--color-accent-500)] opacity-10 blur-2xl"
            >
            </div>
            <h4 class="text-white font-bold text-lg mb-2">Transit Time</h4>
            <p class="text-[var(--color-neutral-300)] text-sm mb-4">
              Classic car transport typically takes 7-14 days depending on the
              route. We prioritize safe handling over speed to ensure no rough
              treatment.
            </p>
            <a
              href="/contact/"
              class="text-[var(--color-accent-400)] text-sm font-bold hover:text-white transition-colors"
              >Enquire about Event Transport →</a
            >
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
