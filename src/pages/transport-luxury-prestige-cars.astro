---
import Layout from '../layouts/Layout.astro';

const title = 'Luxury & Prestige Car Transport | VIP Concierge Service';
const description =
  'White-glove transport service for luxury, sports, and prestige vehicles. Discrete, secure, and prioritized relocation for discerning owners.';

const conciergeFeatures = [
  {
    title: 'Priority Dispatch',
    desc: 'Jump the queue. Prestige bookings receive priority allocation on our next available premium carrier.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Discrete Handling',
    desc: 'Privacy is paramount. Unmarked trailers available upon request for high-profile client relocations.',
    icon: 'M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z',
  },
  {
    title: 'Single-Car Options',
    desc: 'Need it there yesterday? We can arrange dedicated "Hot Shot" single-car transport for urgent deliveries.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<Layout title={title} description={description}>
  {/* Hero Section */}
  <section
    class="relative bg-[var(--color-primary-900)] text-white pt-24 pb-32 overflow-hidden"
  >
    <div class="absolute inset-0 z-0 opacity-20">
      <div
        class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary-950)]/90 to-[var(--color-primary-900)]/50 z-10"
      >
      </div>
      <svg
        class="w-full h-full text-[var(--color-primary-800)]"
        fill="currentColor"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
      >
        <path d="M0 100 C 20 0 50 0 100 100 Z"></path>
      </svg>
    </div>

    <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
      <div
        class="inline-flex items-center gap-2 bg-[var(--color-accent-500)]/10 text-[var(--color-accent-500)] px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-wider mb-8 border border-[var(--color-accent-500)]/20"
      >
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent-500)]"></span>
        VIP Concierge
      </div>
      <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight mb-8">
        Luxury & Prestige <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--color-accent-400)] to-[var(--color-accent-600)]"
          >Vehicle Transport</span
        >
      </h1>
      <p
        class="text-xl text-[var(--color-neutral-400)] leading-relaxed max-w-2xl mx-auto mb-10"
      >
        For when "standard" isn't enough. Experience a white-glove transport
        service designed for high-end sports cars, luxury sedans, and corporate
        relocations.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://ratecheck.movingcars.com.au/quote/v2"
          class="bg-[var(--color-accent-500)] hover:bg-[var(--color-accent-400)] text-[var(--color-primary-950)] font-bold py-4 px-8 rounded-xl transition-all shadow-lg hover:shadow-[var(--color-accent-500)]/20 transform hover:-translate-y-1"
        >
          Request VIP Quote
        </a>
      </div>
    </div>
  </section>

  <main class="bg-[var(--color-neutral-50)] py-20">
    <div class="container mx-auto px-4 max-w-5xl">
      {/* Intro */}
      <div class="prose prose-lg prose-slate mx-auto mb-20 text-center">
        <p class="text-xl leading-relaxed text-[var(--color-neutral-600)]">
          Owning a prestige vehicle is about the experience, and transporting it
          should be no different. Our Luxury Transport division focuses on
          privacy, timing, and impeccable service standards. We bridge the gap
          between standard logistics and a personal concierge.
        </p>
      </div>

      {/* Concierge Grid */}
      <div class="grid md:grid-cols-3 gap-8 mb-24">
        {
          conciergeFeatures.map((item) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-[var(--color-neutral-100)] hover:border-[var(--color-accent-200)] transition-colors">
              <div class="w-12 h-12 bg-[var(--color-primary-50)] text-[var(--color-primary-600)] rounded-xl flex items-center justify-center mb-6">
                <svg
                  class="w-6 h-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d={item.icon}
                  />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-[var(--color-primary-900)] mb-3">
                {item.title}
              </h3>
              <p class="text-[var(--color-neutral-600)] text-sm leading-relaxed">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>

      {/* The Difference Section */}
      <div
        class="bg-[var(--color-primary-900)] rounded-[3rem] p-10 md:p-20 relative overflow-hidden text-white"
      >
        <div class="absolute inset-0 bg-[url('/noise.png')] opacity-5"></div>
        {/* Texture placeholder */}
        <div
          class="absolute top-0 right-0 w-96 h-96 bg-[var(--color-accent-500)] opacity-10 blur-[100px] rounded-full translate-x-1/2 -translate-y-1/2"
        >
        </div>

        <div class="relative z-10 grid md:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-3xl md:text-5xl font-extrabold mb-8">
              More Than Just A Truck
            </h2>
            <p
              class="text-[var(--color-neutral-300)] text-lg leading-relaxed mb-8"
            >
              Standard carriers move cars. We move <span
                class="text-[var(--color-accent-400)] font-bold"
                >investments</span
              >.
              <br /><br />
              Our Prestige service includes direct communication with your dedicated
              transport coordinator, meaning you aren't just a tracking number in
              a system. You have a direct line to the people managing your vehicle's
              journey.
            </p>
            <a
              href="/enclosed-car-transport/"
              class="inline-flex items-center gap-2 text-[var(--color-accent-400)] font-bold hover:text-white transition-colors"
            >
              View Enclosed Carrier Specs
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
              >
            </a>
          </div>
          <div
            class="bg-white/5 backdrop-blur-sm p-8 rounded-2xl border border-white/10"
          >
            <h3 class="font-bold text-xl mb-6 border-b border-white/10 pb-4">
              Service Comparison
            </h3>
            <ul class="space-y-4">
              <li class="flex justify-between items-center">
                <span class="text-[var(--color-neutral-400)]"
                  >Insurance Coverage</span
                >
                <span class="font-bold text-[var(--color-accent-400)]"
                  >Premium Tier</span
                >
              </li>
              <li class="flex justify-between items-center">
                <span class="text-[var(--color-neutral-400)]">Storage</span>
                <span class="font-bold text-[var(--color-accent-400)]"
                  >Indoor Secure</span
                >
              </li>
              <li class="flex justify-between items-center">
                <span class="text-[var(--color-neutral-400)]">Handling</span>
                <span class="font-bold text-[var(--color-accent-400)]"
                  >White Glove</span
                >
              </li>
              <li class="flex justify-between items-center">
                <span class="text-[var(--color-neutral-400)]">Trailer Type</span
                >
                <span class="font-bold text-[var(--color-accent-400)]"
                  >Hard-Sided Enclosed</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
